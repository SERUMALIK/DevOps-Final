{
  "title": "InventoryPro Monitoring",
  "uid": "InventoryPro-001",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Total HTTP Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(increase(http_requests_total[1h]))", "legendFormat": "Requests" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Active Containers",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "count(container_last_seen{name=~\"InventoryPro.*\"})", "legendFormat": "Containers" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 3,
      "title": "Request Rate (5m)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(http_requests_total[5m]))", "legendFormat": "req/s" }],
      "options": { "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "HTTP Errors (5xx)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(increase(http_requests_total{status=~\"5..\"}[1h])) or vector(0)", "legendFormat": "Errors" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 5,
      "title": "HTTP Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum by (handler) (rate(http_requests_total[5m]))", "legendFormat": "{{handler}}" }]
    },
    {
      "id": 6,
      "title": "Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95 latency" }]
    },
    {
      "id": 7,
      "title": "Container CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(container_cpu_usage_seconds_total{name=~\"InventoryPro.*\"}[5m]) * 100", "legendFormat": "{{name}}" }]
    },
    {
      "id": 8,
      "title": "Container Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "container_memory_usage_bytes{name=~\"InventoryPro.*\"} / 1024 / 1024", "legendFormat": "{{name}}" }]
    },
    {
      "id": 9,
      "title": "Container Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{name=~\"InventoryPro.*\"}[5m])", "legendFormat": "{{name}} rx" },
        { "expr": "rate(container_network_transmit_bytes_total{name=~\"InventoryPro.*\"}[5m])", "legendFormat": "{{name}} tx" }
      ]
    },
    {
      "id": 10,
      "title": "HTTP Status Code Breakdown",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum by (status) (increase(http_requests_total[1h]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 11,
      "title": "InventoryPro Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": "Loki",
      "targets": [{ "expr": "{container=~\"/InventoryPro.*\"}", "legendFormat": "" }],
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 12,
      "title": "Backend Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{ "expr": "{container=\"/InventoryPro-backend-1\", detected_level=\"error\"}", "legendFormat": "" }],
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
    }
  ]
}
